# Copy this file to `.env` in the same directory and fill in the values.
# `.env` is gitignored (see repo .gitignore) so secrets never reach the remote.
#
# Scripts that read this file:
#   - scripts/run_ablation.py      (L3 cells only)
#   - scripts/run_multi_seed.py    (L3 baseline)
#
# Loaded by `_load_dotenv()` at import time via python-dotenv. If the file is
# missing, L3 cells are skipped but L0/L1/L2 still run because they don't
# need any API key.

# Required for L3 (LLM) experiments.
OPENAI_API_KEY=

# Optional — only needed if you switch to AnthropicClient.
# ANTHROPIC_API_KEY=

# Optional — override the default L3 model used by run_ablation.py.
# Defaults to gpt-4.1-mini if unset.
# OCT_LLM_MODEL=gpt-4.1-mini
